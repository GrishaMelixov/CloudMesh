# Copy this file to .env and adjust values for local development
# .env is gitignored — never commit real credentials

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=cloudmesh.logs.raw
KAFKA_TOPIC_ERRORS=cloudmesh.logs.errors
KAFKA_GROUP_ID=clickhouse-writers

# ClickHouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=cloudmesh

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_EXCHANGE=cloudmesh.alerts

# gRPC
LOG_COLLECTOR_HOST=log-collector
LOG_COLLECTOR_PORT=50051
GRPC_PORT=50051

# log-producer tuning
EVENTS_PER_SECOND=200
BATCH_SIZE=500
ERROR_RATE_PCT=5
SERVICE_NAMES=payment-service,auth-service,inventory-service,api-gateway

# log-aggregator tuning
CLICKHOUSE_BATCH_SIZE=5000
CLICKHOUSE_FLUSH_INTERVAL_SECONDS=5
ERROR_RATE_THRESHOLD_PCT=10
ERROR_RATE_WINDOW_SECONDS=60

# metrics-api
API_PORT=8000

# CD — set in GitHub Actions secrets, not here
# DOCKERHUB_USERNAME=your-username
# DOCKERHUB_TOKEN=your-token
